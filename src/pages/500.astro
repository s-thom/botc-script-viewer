---
import { Image } from "astro:assets";
import { goblin, witch } from "../generated/character-icons";
import CenteredLayout from "../layouts/CenteredLayout.astro";
import { AppError } from "../types/site";
import { createTranslator, type TranslateParams } from "../lib/i18n";
import LocalisedMessage from "../components/i18n/LocalisedMessage.astro";

interface Props {
  error: unknown;
}

const { error } = Astro.props;

let status = 500;
let titleKey = "viewer.errors.genericError";
let descriptionKey = "viewer.errors.genericErrorDescription";
let descriptionParams: TranslateParams | undefined;

if (error instanceof Error) {
  console.error(error);

  if (error instanceof AppError) {
    titleKey = error.titleKey ?? titleKey;
    descriptionKey = error.descriptionKey ?? descriptionKey;
    descriptionParams = error.descriptionParams;
  }
}

Astro.response.status = status;

const t = createTranslator({ locale: Astro.currentLocale ?? "en" });
---

<CenteredLayout
  t={t}
  meta={{
    title: t.string("viewer.head.title", {
      title: t.string(titleKey),
      nameShort: t.string("viewer.common.nameShort"),
    }),
  }}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <h1><LocalisedMessage t={t} key={titleKey} /></h1>

  <Image
    src={status === 404 ? witch : goblin}
    class="slow-spin"
    alt=""
    width={144}
    densities={[1, 2, 3]}
  />
  <p>
    <LocalisedMessage t={t} key={descriptionKey} params={descriptionParams} />
  </p>
  <p>
    <a href="/"><LocalisedMessage t={t} key="viewer.errors.backToHome" /></a>
  </p>
</CenteredLayout>
