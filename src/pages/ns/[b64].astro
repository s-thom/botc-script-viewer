---
import ScriptViewerLayout from "../../layouts/ScriptViewerLayout.astro";
import { decompressFromBase64 } from "../../lib/compression";
import { MAX_AGE_SECONDS } from "../../lib/constants";
import { createTranslator } from "../../lib/i18n";
import { decodeScript } from "../../lib/number-store";
import { getPathWithoutLocale } from "../../lib/url";

export const prerender = false;

const { b64 } = Astro.params;

if (!b64) {
  return Astro.rewrite("/404");
}

const bytes = await decompressFromBase64(b64, "deflate-raw", true);
const rawScript = decodeScript(bytes);

const t = createTranslator({ locale: Astro.currentLocale ?? "en" });

Astro.response.headers.set(
  "Cache-Control",
  `public, max-age=${MAX_AGE_SECONDS}`,
);
---

<ScriptViewerLayout
  t={t}
  rawScript={rawScript}
  basePath={getPathWithoutLocale(Astro.routePattern, Astro.url.pathname)}
  noIndex
/>
