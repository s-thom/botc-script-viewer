---
import ScriptViewerLayout from "../../../../layouts/ScriptViewerLayout.astro";
import {
  createTranslator,
  ENABLED_LOCALES,
  type LocaleIds,
} from "../../../../lib/i18n";
import { getCollectionRawScript } from "../../../../lib/routes/json";
import { getPathWithoutLocale } from "../../../../lib/url";
import { LOCAL_SCRIPT_COLLECTIONS } from "../../../../scripts";

export function getStaticPaths() {
  return ENABLED_LOCALES.flatMap((locale) =>
    Object.entries(LOCAL_SCRIPT_COLLECTIONS).flatMap(
      ([collectionId, collection]) =>
        collection.scripts.map((script) => ({
          params: {
            collectionId: collectionId as keyof typeof LOCAL_SCRIPT_COLLECTIONS,
            scriptId: script.id,
            locale: locale.isDefault ? undefined : locale.astroId,
          },
        })),
    ),
  );
}

const { collectionId, scriptId } = Astro.params;

const locale = (Astro.currentLocale ?? "en") as LocaleIds;
const rawScript = await getCollectionRawScript(locale, collectionId, scriptId);

const t = await createTranslator({ locale });
---

<ScriptViewerLayout
  t={t}
  rawScript={rawScript}
  basePath={getPathWithoutLocale(Astro.routePattern, Astro.url.pathname)}
  overrideJsonPathSegment={`${scriptId}.json`}
/>
