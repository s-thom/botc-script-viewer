---
import ScriptViewerLayout from "../../../../layouts/ScriptViewerLayout.astro";
import { MAX_AGE_SECONDS } from "../../../../lib/constants";
import { createTranslator } from "../../../../lib/i18n";
import { getNSRawScript } from "../../../../lib/routes/json";
import { getPathWithoutLocale } from "../../../../lib/url";

export const prerender = false;

const { b64 } = Astro.params;

if (!b64) {
  return Astro.rewrite("/404");
}

const rawScript = await getNSRawScript(b64);

const t = await createTranslator({ locale: Astro.currentLocale ?? "en" });

Astro.response.headers.set(
  "Cache-Control",
  `public, max-age=${MAX_AGE_SECONDS}`,
);
---

<ScriptViewerLayout
  t={t}
  rawScript={rawScript}
  basePath={getPathWithoutLocale(Astro.routePattern, Astro.url.pathname)}
  noIndex
/>
