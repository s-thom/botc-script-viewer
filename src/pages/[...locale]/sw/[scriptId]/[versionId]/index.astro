---
import ScriptSidebarExtra from "../../../../../components/display/ScriptSidebarExtra.astro";
import LocalisedMessage from "../../../../../components/i18n/LocalisedMessage.astro";
import type { BloodOnTheClocktowerCustomScript } from "../../../../../generated/script-schema";
import ScriptViewerLayout from "../../../../../layouts/ScriptViewerLayout.astro";
import { MAX_AGE_SECONDS } from "../../../../../lib/constants";
import { createTranslator, type LocaleIds } from "../../../../../lib/i18n";
import { fetchScriptByIdVersion } from "../../../../../lib/import/botcscripts";
import { getPathWithoutLocale } from "../../../../../lib/url";

export const prerender = false;

const { scriptId, versionId } = Astro.params;

if (!(scriptId && versionId)) {
  return Astro.rewrite("/404");
}

const rawScriptString = await fetchScriptByIdVersion(scriptId, versionId);

const rawScript: BloodOnTheClocktowerCustomScript = JSON.parse(rawScriptString);

const locale = (Astro.currentLocale ?? "en") as LocaleIds;
const t = await createTranslator({ locale });

Astro.response.headers.set(
  "Cache-Control",
  `public, max-age=${MAX_AGE_SECONDS}`,
);
---

<ScriptViewerLayout
  t={t}
  rawScript={rawScript}
  basePath={getPathWithoutLocale(
    Astro.routePattern,
    Astro.currentLocale,
    Astro.url.pathname,
  )}
  noIndex
>
  <ScriptSidebarExtra
    slot="sidebar-after-description"
    iconCharacterId="grandmother"
  >
    <LocalisedMessage
      t={t}
      key="viewer.script.viewOnBotcScripts"
      params={{
        externalLink: `https://www.botcscripts.com/script/${scriptId}/${versionId}`,
      }}
    />
  </ScriptSidebarExtra>
</ScriptViewerLayout>
