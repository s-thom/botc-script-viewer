---
import type { SvgComponent } from "astro/types";
import { Image } from "astro:assets";
import { getRelativeLocaleUrl } from "astro:i18n";
import deIcon from "language-icons/icons/de.svg";
import ptIcon from "language-icons/icons/pt.svg";
import enIcon from "language-icons/icons/en.svg";
import esIcon from "language-icons/icons/es.svg";
import frIcon from "language-icons/icons/fr.svg";
import switchIcon from "../../assets/language-switch.webp";
import {
  ENABLED_LOCALES,
  type LocaleIds,
  type Translator,
} from "../../lib/i18n";

const ICON_COMPONENTS: Record<LocaleIds, SvgComponent> = {
  en: enIcon,
  "en-7c": enIcon,
  fr: frIcon,
  fr_community: frIcon,
  de: deIcon,
  "de-ch": deIcon,
  es: esIcon,
  es_community: esIcon,
  "es-mx": esIcon,
  "es-419": esIcon,
  pt: ptIcon,
  pt_community: ptIcon,
  "pt-br": ptIcon,
  "pt-br_community": ptIcon,
};

interface Props {
  t: Translator;
  basePath: string;
}

const { t, basePath } = Astro.props;

const CurrentLocaleIcon = ICON_COMPONENTS[t.locale as LocaleIds];
---

<div>
  <button
    type="button"
    class="language-button"
    popovertarget="language-selector"
  >
    <Image
      src={switchIcon}
      width={32}
      height={32}
      densities={[1, 2, 3]}
      alt={t.string("viewer.navigation.selectLanguage").value}
    />
    {
      CurrentLocaleIcon && (
        <CurrentLocaleIcon
          class="current-icon"
          width={12}
          height={12}
          viewBox="0 0 128 128"
        />
      )
    }
  </button>
  <dialog
    id="language-selector"
    class="popover"
    aria-label={t.string("viewer.navigation.selectLanguage").value}
    popover
  >
    <nav class="popover-content">
      <ul class="language-list">
        {
          ENABLED_LOCALES.map((locale) => {
            const LanguageIcon = ICON_COMPONENTS[locale.astroId];

            return (
              <li>
                <a
                  class:list={[
                    "language-link",
                    locale.astroId === t.locale && "current",
                  ]}
                  href={getRelativeLocaleUrl(locale.astroId, basePath)}
                  hreflang={locale.astroId}
                >
                  <LanguageIcon width={24} height={24} viewBox="0 0 128 128" />
                  {locale.name}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </dialog>
</div>

<style>
  .language-button {
    position: relative;
    display: block;
    padding: 0;
    border: none;
    width: 32px;
    height: 32px;
    background: transparent;
    anchor-name: --language-selector;
  }

  .current-icon {
    position: absolute;
    inset-block-end: 0;
    inset-inline-end: 0;
  }

  .popover {
    max-width: min(100vi, 500px);
    width: 100%;
    border: 0;
    padding: 0;
  }
  @supports (position-anchor: unset) {
    .popover {
      position: absolute;
      position-anchor: --language-selector;
      position-area: end span-all;
      inset-block-start: 4px;
    }

    @media (min-width: 500px) {
      .popover {
        position-area: end span-start;
      }
    }
  }

  .popover-content {
    border: 4px solid var(--color-header-paper);
    background: var(--color-background);
    padding: 16px;
    width: 100%;
  }

  .language-list {
    width: 100%;
    display: grid;
    gap: 0.5rem;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    list-style: none;
    padding-inline-start: 0;
  }

  .language-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.2rem 0.4rem;
    border-radius: 8px;
    border: 2px solid transparent;

    &:hover,
    &:focus-within {
      border-color: var(--color-control-border-hover);
      background-color: var(--color-control-background-hover);
    }

    &:active {
      background-color: var(--color-control-background-active);
      border-color: var(--color-control-border-active);
    }

    &.current {
      background-color: var(--color-control-background-active);
      border-color: var(--color-control-border-active);
    }
  }
</style>
