---
import type { Translator } from "../../lib/i18n/types";
import type { NormalisedScript } from "../../types/botc";
import LocalisedMessage from "../i18n/LocalisedMessage.astro";
import BootleggerList from "./BootleggerList.astro";
import CharacterIcon from "./CharacterIcon.astro";
import ScriptSidebarExtra from "./ScriptSidebarExtra.astro";

interface Props {
  t: Translator;
  script: NormalisedScript;
  collectionId?: string;
  scriptId?: string;
}
const { t, script, collectionId, scriptId } = Astro.props;
---

<div class="script-sidebar screen-only flow">
  <h2 id="script" class="title">
    {script.name || t.string("viewer.script.untitledScript").value}
  </h2>
  {
    script.author && (
      <p class="author">
        <LocalisedMessage
          t={t}
          key="viewer.script.byAuthor"
          params={{ author: script.author }}
        />
      </p>
    )
  }

  {
    collectionId === "base3" && scriptId && (
      <p class="description">
        <LocalisedMessage
          t={t}
          key={`game.editions.${scriptId}.description`}
          params={{ author: script.author }}
        />
      </p>
    )
  }

  <slot name="after-description" />

  {
    script.teams.fabled.length + script.teams.loric.length > 0 && (
      <ul class="fabled-list">
        {script.teams.fabled.map((character) => (
          <li class="fabled-list-item">
            <a href={`#${character.id}`} class="fabled-list-item">
              <CharacterIcon size={48} character={character} />
              <span class="fabled-title">{character.name}</span>
            </a>
          </li>
        ))}
        {script.teams.loric.map((character) => (
          <li class="fabled-list-item">
            <a href={`#${character.id}`} class="fabled-list-item">
              <CharacterIcon size={48} character={character} />
              <span class="fabled-title">{character.name}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }

  {
    script.bootlegger && script.bootlegger.length > 0 && (
      <BootleggerList t={t} rules={script.bootlegger} />
    )
  }

  {
    script.charactersById.has("pukka") && (
      <ScriptSidebarExtra iconCharacterId="pukka">
        <LocalisedMessage
          t={t}
          key="viewer.pukka.view"
          params={{
            link: "/pukka-flowchart",
            content: t.string("viewer.pukka.title").value,
          }}
        />
      </ScriptSidebarExtra>
    )
  }

  <slot name="after-extras" />
</div>

<style>
  .script-sidebar {
    margin: 2rem 1rem;

    @media (min-width: 900px) {
      margin: 2rem;
    }

    @media (min-width: 1200px) {
      position: sticky;
      top: 1rem;
      height: fit-content;

      margin: 1rem;
      padding: 1rem;

      background-color: var(--color-control-background);
      border: 2px solid var(--color-control-border);
      border-radius: 15px;
      color: var(--color-text);
    }
  }

  .title {
    font-size: 2rem;
  }

  .author {
    font-size: 1.5rem;
    --flow-space: 0em;
  }

  .description {
    --flow-space: 0em;
  }

  .fabled-list {
    flex-grow: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    list-style: none;
    padding-inline-start: 0;
  }

  .fabled-list-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
  }

  .fabled-title {
    font-family: var(--font-title);
    font-size: 1.2rem;
  }
</style>
