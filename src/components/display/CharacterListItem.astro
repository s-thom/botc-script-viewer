---
import type { Translator } from "../../lib/i18n/types";
import type { NormalisedScriptCharacter } from "../../types/botc";
import LocalisedMessage from "../i18n/LocalisedMessage.astro";
import MessageSegments from "../i18n/MessageSegments.astro";
import CharacterIcon from "./CharacterIcon.astro";

interface Props {
  t: Translator;
  characters: NormalisedScriptCharacter[];
  characterLinks?: string[];
  title?: string;
  description?: string;
  titleLink?: string;
  wikiLink?: string;
  iconSize?: number;
  iconClass?: string;
}

const {
  t,
  characters,
  characterLinks,
  title,
  description,
  titleLink,
  wikiLink,
  iconSize = 48,
  iconClass,
} = Astro.props;
---

<div class="character">
  {characters.length === 0 && <div class="character-icon-placeholder" />}
  {
    characters.map((character, i) =>
      characterLinks?.[i] ? (
        <a class="character-icon-link" href={characterLinks[i]}>
          <CharacterIcon
            character={character}
            size={iconSize}
            class:list={["character-icon-offset", iconClass]}
          />
        </a>
      ) : (
        <CharacterIcon
          character={character}
          size={iconSize}
          class:list={["character-icon-offset", iconClass]}
        />
      ),
    )
  }
  <div class="character-info">
    {
      title && (
        <div class="character-title-area">
          <span class="character-title">
            {titleLink ? (
              <a class="character-title-link" href={titleLink}>
                <MessageSegments segments={t.raw(title)} />
              </a>
            ) : (
              <MessageSegments segments={t.raw(title)} />
            )}
          </span>
          {wikiLink && (
            <a
              class="character-wiki-link"
              href={wikiLink}
              rel="external noreferrer"
              target="_blank"
              aria-label={t.string("viewer.script.wikiLabel", { title }).value}
            >
              <LocalisedMessage t={t} key="viewer.script.wikiLink" />
            </a>
          )}
        </div>
      )
    }
    {
      description && (
        <p class="character-description">
          <MessageSegments
            segments={t.raw(description, { formatReplacements: true })}
            character={characters[0] ?? undefined}
          />
        </p>
      )
    }
  </div>
</div>

<style>
  .character {
    display: flex;
    align-items: flex-start;

    &:not(:is(:hover, :focus-within)) {
      .character-wiki-link {
        opacity: 0;
      }
    }
  }

  :global(.character-icon-offset) {
    translate: -4px -4px;
  }

  .character-icon-placeholder {
    width: 48px;
  }

  .character-icon-link {
    display: contents;
  }

  .character-title-area {
    display: flex;
    gap: 0.5rem;
    justify-content: space-between;
  }

  .character-title {
    font-family: var(--font-title);
    font-size: 1.3rem;
  }

  .character-title-link:not(:is(:hover, :focus-within)) {
    text-decoration: none;
  }

  .character-description {
    line-height: 1.3rem;
  }

  .character-wiki-link {
    align-self: start;
    font-size: 0.8em;
  }
</style>
