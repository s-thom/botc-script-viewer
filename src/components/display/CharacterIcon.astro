---
import type { GetImageResult, ImageMetadata } from "astro";
import { getImage, Image } from "astro:assets";
import * as APP_ICONS from "../../assets/botc";
import { CHARACTERS_BY_ID } from "../../lib/characters";
import { ALLOWED_EXTERNAL_HOSTNAMES } from "../../lib/constants";
import type { NormalisedScriptCharacter } from "../../types/botc";

interface Props {
  character: NormalisedScriptCharacter;
  size: number;
  includeAlt?: boolean;
  loading?: "eager" | "lazy";
  class?: string;
}

type FallbackProps = Pick<GetImageResult, "src" | "srcSet" | "attributes">;

const {
  character,
  size,
  includeAlt = true,
  class: className,
  loading = "eager",
} = Astro.props;

function getFallbackIcon(team: NormalisedScriptCharacter["team"]): string {
  return `https://release.botc.app/resources/characters/generic/${team}.webp`;
}

function ensureImageHostname(
  character: NormalisedScriptCharacter,
  imageUrl: string,
): string {
  try {
    const url = new URL(imageUrl);
    if (ALLOWED_EXTERNAL_HOSTNAMES.includes(url.hostname)) {
      return imageUrl;
    }
    // eslint-disable-next-line @typescript-eslint/no-unused-vars
  } catch (err) {
    // Do nothing
  }
  return getFallbackIcon(character.team);
}

function getCharacterIcon(
  character: NormalisedScriptCharacter,
): string | ImageMetadata {
  // Check for images defined in script
  if (typeof character.image === "string") {
    return ensureImageHostname(character, character.image);
  }
  if (Array.isArray(character.image)) {
    switch (character.team) {
      case "townsfolk":
      case "outsider":
        return ensureImageHostname(character, character.image[0]);
      case "minion":
      case "demon":
        return ensureImageHostname(character, character.image[0]);
      case "traveller":
        return ensureImageHostname(character, character.image[0]);
      case "fabled":
        return ensureImageHostname(character, character.image[0]);
    }
  }

  // Role has no image defined, check for special characters first. use local image if official character.
  if (character.edition === "special") {
    return (
      (APP_ICONS as Partial<Record<string, ImageMetadata>>)[character.id] ??
      getFallbackIcon(character.team)
    );
  }

  // If its an official character, use the official icon.
  if (CHARACTERS_BY_ID.has(character.id)) {
    let alignmentSuffix = "";
    switch (character.team) {
      case "townsfolk":
      case "outsider":
        alignmentSuffix = "_g";
        break;
      case "minion":
      case "demon":
        alignmentSuffix = "_e";
        break;
    }

    return `https://release.botc.app/resources/characters/${character.edition}/${character.id}${alignmentSuffix}.webp`;
  }

  // Otherwise return default icon for type
  return getFallbackIcon(character.team);
}

const icon = getCharacterIcon(character);

const fallbackMetadata = getFallbackIcon(character.team);
const fallbackResult = await getImage({
  src: fallbackMetadata,
  width: size,
  height: size,
  densities: [1, 2, 3],
});

const fallback: FallbackProps = {
  src: fallbackResult.src,
  srcSet: fallbackResult.srcSet,
  attributes: fallbackResult.attributes,
};
---

{
  // Make Typescript happy by having both branches explicitly.
  typeof icon === "string" ? (
    <Image
      src={icon}
      alt={includeAlt ? character.name : ""}
      class:list={["character-icon", className]}
      width={size}
      height={size}
      densities={[1, 2, 3]}
      loading={loading}
      data-fallback={JSON.stringify(fallback)}
    />
  ) : (
    <Image
      src={icon}
      alt={includeAlt ? character.name : ""}
      class:list={["character-icon", className]}
      width={size}
      height={size}
      densities={[1, 2, 3]}
      loading={loading}
    />
  )
}

<script>
  import type { GetImageResult } from "astro";
  type FallbackProps = Pick<GetImageResult, "src" | "srcSet" | "attributes">;

  document
    .querySelectorAll<HTMLImageElement>("img.character-icon[data-fallback]")
    .forEach((img) => {
      img.addEventListener(
        "error",
        () => {
          console.log(
            `Error loading icon for character ${img.alt}. Switching to team fallback`,
          );

          const fallback: FallbackProps = JSON.parse(img.dataset.fallback!);

          img.src = fallback.src;
          img.srcset = fallback.srcSet.attribute;
          for (const [name, value] of Object.entries(fallback.attributes)) {
            img.setAttribute(name, value);
          }
        },
        { once: true },
      );
    });
</script>

<style>
  .character-icon {
    aspect-ratio: 1/1;
  }
</style>
