---
import type { TranslateParams } from "../../lib/i18n";
import type { Translator } from "../../lib/i18n/types";
import type { NormalisedScriptCharacter } from "../../types/botc";
import MessageSegments from "./MessageSegments.astro";

export interface Props {
  t: Translator;
  key: string;
  params?: TranslateParams;
  character?: NormalisedScriptCharacter;
}

const { t, key, params, character } = Astro.props;

const { value, fallbackLocale } = t(key, params);
---

<MessageSegments
  segments={value}
  overrideLocale={fallbackLocale}
  character={character}
/>
