---
import type { MarkdownLayoutProps } from "astro";
import TopBarLayout from "./TopBarLayout.astro";
import Footer from "../components/misc/Footer.astro";

type Props = MarkdownLayoutProps<{
  title: string;
}>;

const { frontmatter } = Astro.props;
---

<TopBarLayout meta={{ title: `${frontmatter.title}` }}>
  <div class="md flow">
    <h1>{frontmatter.title}</h1>

    <slot />

    <Footer />
  </div>
</TopBarLayout>

<style>
  .md {
    margin: 0 auto;
    max-width: 60rem;
    padding: 2rem;
  }
</style>
