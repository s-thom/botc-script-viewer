{
  "name": "botc-script-viewer",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "setup": "wrangler types && node setup/generate-script-schema.ts && node setup/download-role-icons.ts && node setup/download-translations.ts && node setup/generate-community-translations.ts && node setup/generate-edition-scripts.ts && node setup/generate-official-character-ids.ts",
    "validate": "node setup/ensure-characters-in-number-store.ts",
    "dev": "astro dev",
    "build": "astro build",
    "full-build": "npm run setup && npm run build",
    "preview": "astro preview",
    "lint": "eslint .",
    "astro": "astro",
    "test": "node --test",
    "test:e2e": "playwright test",
    "test:all": "node --test && playwright test"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.2",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.4",
    "culori": "^4.0.2",
    "idb": "^8.0.3",
    "language-icons": "^0.3.0",
    "qrcode-svg": "^1.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/compat": "^2.1.0",
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.2",
    "@playwright/test": "^1.61.1",
    "@types/culori": "^4.0.1",
    "@types/node": "^26.0.1",
    "@types/qrcode-svg": "^1.1.5",
    "@types/umami": "^2.10.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "fflate": "^0.8.2",
    "json-schema-to-typescript": "^15.0.4",
    "p-queue": "^9.3.0",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "public-google-sheets-parser": "^1.5.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "wrangler": "^4.106.0"
  }
}
